# Copy this file to .env in the repo root and fill in values.
# .env is gitignored — never commit secrets.

# Optional: store memory and personalities outside the default data dir
# BUDDY_DATA_DIR=D:\Google Drive\Buddy

# Camera for capture_camera (optional; Windows name lookup uses DirectShow)
# BUDDY_CAMERA_NAME=OBS Virtual Camera
# BUDDY_CAMERA_DEVICE=3

# Telegram mobile chat (optional — bridge starts only when token is set)
# TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz
# TELEGRAM_ALLOWED_CHAT_IDS=123456789

# Episodic memory session lifecycle (optional overrides)
# BUDDY_EPISODIC_IDLE_TIMEOUT_MINUTES=20
# BUDDY_EPISODIC_MAX_SESSION_MINUTES=120
# BUDDY_EPISODIC_TIMEZONE=America/New_York
# BUDDY_EPISODIC_CONSOLIDATION_DELAY_SECONDS=30
# BUDDY_EPISODIC_CONSOLIDATION_RETRY_BASE_SECONDS=60

# Episodic semantic search (optional overrides)
# BUDDY_EPISODIC_EMBED_MODEL=BAAI/bge-small-en-v1.5
# BUDDY_EPISODIC_SEARCH_DEFAULT_LIMIT=10

# Local LLM (llama-server + voice + episodic consolidation) — set model name once here
# BUDDY_LLM_MODEL_NAME=gemma-4-12b-it-uncensored-Q4_K_M
# BUDDY_LLM_BASE_URL=http://127.0.0.1:8080/v1
# BUDDY_LLM_MODEL_DIR=D:\Llama\Models
# BUDDY_LLM_MMPROJ=mmproj-gemma-4-12B-it-bf16.gguf
# BUDDY_LLM_SERVER_EXE=D:\Llama\llama-server.exe
